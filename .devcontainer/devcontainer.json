// trunk-ignore-all(cspell)
{
  "image": "mcr.microsoft.com/devcontainers/base:1-ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers-contrib/features/haskell:2": {},
    "ghcr.io/trunk-io/devcontainer-feature/trunk:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": ["haskell.haskell", "streetsidesoftware.code-spell-checker", "bierner.github-markdown-preview", "bierner.emojisense", "Tyriar.lorem-ipsum"]
    }
  },
  "updateContentCommand": "trunk install"
}
