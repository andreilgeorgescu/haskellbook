{
  "cSpell.checkOnlyEnabledFileTypes": false,
  "cSpell.files": ["src/", "test/", "readme.md"],
  "cSpell.ignorePaths": [],
  "cSpell.language": "en-US",
  "cSpell.noConfigSearch": true,
  "cSpell.showAutocompleteSuggestions": true,
  "cSpell.suggestionMenuType": "quickFix",
  "cSpell.useGitignore": false,
  "terminal.integrated.defaultProfile.linux": "zsh",
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "trunk.io",
  "trunk.autoInit": false,
  "files.autoSave": "off",
  "trunk.inlineDecorators": false,
  "[haskell]": {
    "editor.defaultFormatter": "haskell.haskell"
  },
  "emojisense.languages": {
    "markdown": true,
    "plaintext": false,
    "scminput": false,
    "git-commit": false
  },
  "emojisense.unicodeCompletionsEnabled": false,
  "yaml.format.enable": false,
  "yaml.validate": false,
  "yaml.extension.recommendations": false,
  "cSpell.diagnosticLevel": "Error"
}
